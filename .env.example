# 이 파일을 .env로 복사한 뒤 값을 채운다. .env는 절대 커밋하지 않는다.

# true면 실제 주문 대신 모의 체결만 기록한다. 실거래 전환 전까지 반드시 true 유지.
DRY_RUN=true

# 전략 판단용. dry-run에도 필요하다.
ANTHROPIC_API_KEY=

# 실거래 전환 시점에만 발급한다. dry-run은 공개 시세 API만 쓰므로 비워둬도 된다.
# 발급 시 "자산조회 + 주문" 권한만 체크하고 출금 권한은 절대 주지 않는다.
# 허용 IP 등록이 필수이므로 고정 IP(VPS)에서 발급한다.
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# 선택: 손절 체결/서킷브레이커/예산 정지/주간 평가 알림
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
